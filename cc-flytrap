#!/usr/bin/env bash
#
# cc-flytrap CLI
# Claude Code System Prompt Stripper
#

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BIN_DIR="$SCRIPT_DIR"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_err() { echo -e "${RED}[ERROR]${NC} $1"; }
log_step() { echo -e "${CYAN}[STEP]${NC} $1"; }

detect_os() {
    case "$(uname -s)" in
        Darwin*) echo "macos" ;;
        Linux*) echo "linux" ;;
        *) echo "unknown" ;;
    esac
}

check_deps() {
    if ! command -v mitmdump &> /dev/null; then
        log_err "mitmproxy not found. Install with:"
        case "$(detect_os)" in
            macos) echo "  brew install mitmproxy" ;;
            linux) echo "  sudo apt install mitmproxy" ;;
        esac
        exit 1
    fi
    
    if [ ! -f "$HOME/.mitmproxy/mitmproxy-ca-cert.pem" ]; then
        log_warn "CA certificate not found"
        log_step "Run 'mitmproxy' once, then install cert from http://mitm.it"
        exit 1
    fi
}

check_files() {
    if [ ! -f "$SCRIPT_DIR/cc-flytrap.py" ]; then
        log_err "cc-flytrap.py not found in $SCRIPT_DIR"
        exit 1
    fi
}

usage() {
    echo "cc-flytrap - Claude Code System Prompt Stripper"
    echo ""
    echo "Usage: cc-flytrap <command>"
    echo ""
    echo "Commands:"
    echo "  start       Start the proxy (manual mode)"
    echo "  stop        Stop the proxy"
    echo "  status      Check if proxy is running"
    echo "  test        Run smoke test"
    echo "  install     Install as background service (auto-start)"
    echo "  uninstall   Remove background service"
    echo "  version     Show version"
    echo "  help        Show this help"
    echo ""
    echo "First time setup:"
    echo "  1. Install mitmproxy: brew install mitmproxy"
    echo "  2. Run 'mitmproxy' once to generate CA"
    echo "  3. Install cert from http://mitm.it to system keychain"
    echo "  4. cc-flytrap install"
    exit 1
}

cmd_start() {
    check_files
    log_info "Starting proxy..."
    local pid_file="$SCRIPT_DIR/.cc-flytrap.pid"
    
    if [ -f "$pid_file" ]; then
        local old_pid=$(cat "$pid_file" 2>/dev/null)
        if [ -n "$old_pid" ] && kill -0 "$old_pid" 2>/dev/null; then
            log_warn "Already running (PID $old_pid)"
            return 0
        fi
        rm -f "$pid_file"
    fi
    
    mitmdump -p 3128 -s "$SCRIPT_DIR/cc-flytrap.py" 2>&1 &
    local pid=$!
    echo $pid > "$pid_file"
    sleep 1
    
    if kill -0 "$pid" 2>/dev/null; then
        log_info "Started (PID $pid)"
    else
        log_err "Failed to start"
        rm -f "$pid_file"
        exit 1
    fi
}

cmd_stop() {
    log_info "Stopping proxy..."
    local pid_file="$SCRIPT_DIR/.cc-flytrap.pid"
    
    if [ -f "$pid_file" ]; then
        local pid=$(cat "$pid_file" 2>/dev/null)
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            kill "$pid" 2>/dev/null || true
            sleep 1
            kill -9 "$pid" 2>/dev/null || true
        fi
        rm -f "$pid_file"
    fi
    
    lsof -ti :3128 | xargs kill 2>/dev/null || true
    log_info "Stopped"
}

cmd_status() {
    local pid_file="$SCRIPT_DIR/.cc-flytrap.pid"
    local running=false
    
    if [ -f "$pid_file" ]; then
        local pid=$(cat "$pid_file" 2>/dev/null)
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            log_info "Running (PID $pid)"
            running=true
        fi
    fi
    
    if lsof -i :3128 &>/dev/null; then
        log_info "Port 3128 in use"
        running=true
    fi
    
    if [ "$running" = "false" ]; then
        log_warn "Not running"
    fi
    
    local os=$(detect_os)
    if [ "$os" = "macos" ]; then
        if launchctl list 2>/dev/null | grep -q cc-flytrap; then
            log_info "Service registered:"
            launchctl list | grep cc-flytrap
        fi
    elif [ "$os" = "linux" ]; then
        if systemctl --user is-active --quiet cc-flytrap 2>/dev/null; then
            log_info "Service registered"
        fi
    fi
}

cmd_test() {
    check_deps
    check_files
    log_info "Running smoke test..."
    
    # Test 1: Claude responds
    local response
    response=$(HTTP_PROXY=http://127.0.0.1:3128 \
        HTTPS_PROXY=http://127.0.0.1:3128 \
        NODE_EXTRA_CA_CERTS=~/.mitmproxy/mitmproxy-ca-cert.pem \
        claude -p "test" 2>&1 | grep -v "^\[" | head -1)
    
    if [ -z "$response" ]; then
        log_err "Smoke test failed: no response"
        exit 1
    fi
    log_info "Claude: $response"
    
    # Test 2: Check logs
    sleep 1
    if [ -f "$SCRIPT_DIR/logs/launchd.log" ] || [ -f "$SCRIPT_DIR/logs/systemd.log" ]; then
        local log_file="$SCRIPT_DIR/logs/launchd.log"
        [ -f "$SCRIPT_DIR/logs/systemd.log" ] && log_file="$SCRIPT_DIR/logs/systemd.log"
        
        local modified=$(grep "Modified:" "$log_file" 2>/dev/null | tail -1)
        if [ -n "$modified" ]; then
            log_info "Stripping: $modified"
            local new_words=$(echo "$modified" | grep -oE '[0-9]+ words' | tail -1 | awk '{print $1}')
            if [ -n "$new_words" ] && [ "$new_words" -lt 500 ] 2>/dev/null; then
                log_info "SUCCESS: ~95% reduction"
            fi
        fi
    fi
    
    log_info "=== All tests passed ==="
}

cmd_install() {
    check_deps
    check_files
    mkdir -p "$SCRIPT_DIR/logs"
    
    local os=$(detect_os)
    log_info "Installing on $os..."
    
    if [ "$os" = "macos" ]; then
        local plist="$HOME/Library/LaunchAgents/com.cc-flytrap.proxy.plist"
        mkdir -p "$HOME/Library/LaunchAgents"
        
        cat > "$plist" << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.cc-flytrap.proxy</string>
    <key>ProgramArguments</key>
    <array>
        <string>__MITMDUMP__</string>
        <string>-p</string>
        <string>3128</string>
        <string>-s</string>
        <string>__SCRIPT__</string>
    </array>
    <key>WorkingDirectory</key>
    <string>__CWD__</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>__LOGDIR__/launchd.log</string>
    <key>StandardErrorPath</key>
    <string>__LOGDIR__/launchd.log</string>
    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
EOF
        
        local mitm_path=$(which mitmdump)
        sed -i '' "s|__MITMDUMP__|$mitm_path|g" "$plist"
        sed -i '' "s|__SCRIPT__|$SCRIPT_DIR/cc-flytrap.py|g" "$plist"
        sed -i '' "s|__CWD__|$SCRIPT_DIR|g" "$plist"
        sed -i '' "s|__LOGDIR__|$SCRIPT_DIR/logs|g" "$plist"
        
        launchctl unload "$plist" 2>/dev/null || true
        launchctl load "$plist"
        log_info "Service installed: $plist"
        
    elif [ "$os" = "linux" ]; then
        local svc_dir="$HOME/.config/systemd/user"
        local svc_file="$svc_dir/cc-flytrap.service"
        mkdir -p "$svc_dir"
        
        cat > "$svc_file" << 'EOF'
[Unit]
Description=cc-flytrap - Claude Code System Prompt Stripper
After=network.target

[Service]
Type=simple
User=__USER__
WorkingDirectory=__CWD__
ExecStart=__MITMDUMP__ -p 3128 -s __CWD__/cc-flytrap.py
Restart=always
RestartSec=5

StandardOutput=append:__LOGDIR__/systemd.log
StandardError=append:__LOGDIR__/systemd.log

[Install]
WantedBy=multi-user.target
EOF
        
        local mitm_path=$(which mitmdump)
        sed -i "s|__USER__|$USER|g" "$svc_file"
        sed -i "s|__MITMDUMP__|$mitm_path|g" "$svc_file"
        sed -i "s|__CWD__|$SCRIPT_DIR|g" "$svc_file"
        sed -i "s|__LOGDIR__|$SCRIPT_DIR/logs|g" "$svc_file"
        
        systemctl --user daemon-reload 2>/dev/null || true
        systemctl --user enable cc-flytrap.service 2>/dev/null || true
        systemctl --user restart cc-flytrap.service
        log_info "Service installed: $svc_file"
    fi
    
    log_info "=== Install complete ==="
    log_info "Run: cc-flytrap test"
}

cmd_uninstall() {
    local os=$(detect_os)
    
    if [ "$os" = "macos" ]; then
        local plist="$HOME/Library/LaunchAgents/com.cc-flytrap.proxy.plist"
        if [ -f "$plist" ]; then
            launchctl unload "$plist" 2>/dev/null || true
            rm -f "$plist"
            log_info "Removed: $plist"
        fi
    elif [ "$os" = "linux" ]; then
        systemctl --user stop cc-flytrap 2>/dev/null || true
        systemctl --user disable cc-flytrap 2>/dev/null || true
        rm -f "$HOME/.config/systemd/user/cc-flytrap.service"
        log_info "Removed systemd service"
    fi
    
    log_info "=== Uninstall complete ==="
}

# Main
VERSION="0.0.0"

case "$1" in
    start) cmd_start ;;
    stop) cmd_stop ;;
    status) cmd_status ;;
    test) cmd_test ;;
    install) cmd_install ;;
    uninstall) cmd_uninstall ;;
    version|--version|-v) echo "cc-flytrap v$VERSION" ;;
    help|--help|-h) usage ;;
    *) usage ;;
esac