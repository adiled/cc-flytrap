#!/usr/bin/env bash
#
# ccft-status - Report flytrap state.
#
# Single source of truth: flytrap_state in ccft-lib.
# Outputs one human line; exits 0 if running, 1 if not.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/ccft-lib"
load_config

state=$(flytrap_state)
owner=$(echo "$state" | cut -d'|' -f1)
pid=$(echo "$state"   | cut -d'|' -f2)
port_pids=$(echo "$state" | cut -d'|' -f3)

case "$owner" in
    launchd)
        echo "Running on $PROXY_HOST:$PROXY_PORT (PID $pid, managed by launchd)"
        ;;
    systemd)
        echo "Running on $PROXY_HOST:$PROXY_PORT (PID $pid, managed by systemd)"
        ;;
    manual)
        echo "Running on $PROXY_HOST:$PROXY_PORT (PID $pid, started manually)"
        ;;
    launchd-idle)
        if [ -n "$port_pids" ]; then
            echo "Port $PROXY_PORT in use by external process (PID $port_pids); launchd unit registered but idle"
        else
            echo "Not running (launchd unit registered but idle — try 'ccft start')"
        fi
        exit 1
        ;;
    systemd-idle)
        if [ -n "$port_pids" ]; then
            echo "Port $PROXY_PORT in use by external process (PID $port_pids); systemd unit registered but inactive"
        else
            echo "Not running (systemd unit registered but inactive — try 'ccft start')"
        fi
        exit 1
        ;;
    none)
        if [ -n "$port_pids" ]; then
            echo "Not running, but port $PROXY_PORT held by foreign process (PID $port_pids)"
            exit 1
        fi
        echo "Not running"
        exit 1
        ;;
esac

# Sanity: did the owner's pid actually take the port?
if [ -n "$pid" ] && [ -n "$port_pids" ] && ! echo " $port_pids " | grep -q " $pid "; then
    log_warn "Owner reports PID $pid but port $PROXY_PORT held by $port_pids — possible drift"
fi

exit 0
