#!/usr/bin/env bash
#
# ccft-status - Check flytrap status

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/ccft-lib"

running=false
pid_file="$SCRIPT_DIR/../.ccft.pid"

if [ -f "$pid_file" ]; then
    pid=$(cat "$pid_file" 2>/dev/null)
    if [ -n "$pid" ] && kill -0 $pid 2>/dev/null; then
        echo "Running (PID $pid)"
        running=true
    fi
fi

if lsof -i:$PROXY_PORT &>/dev/null; then
    echo "Port $PROXY_PORT in use"
    running=true
fi

if [ "$running" = "false" ]; then
    echo "Not running"
fi

if [ "$(uname -s)" = "Darwin" ]; then
    if launchctl list 2>/dev/null | grep -q "com.ccft"; then
        echo "Service registered:"
        launchctl list | grep "com.ccft"
    fi
fi