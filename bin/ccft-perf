#!/usr/bin/env bash
#
# ccft-perf - ccft's own observability layer
#   Answers: "is ccft slowing my requests down?"

set -e
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

candidates=(
    "$SCRIPT_DIR/../perf.py"
    "$HOME/.local/share/ccft/perf.py"
    "$SCRIPT_DIR/perf.py"
)

perf_py=""
for p in "${candidates[@]}"; do
    if [ -f "$p" ]; then
        perf_py="$p"
        break
    fi
done

if [ -z "$perf_py" ]; then
    echo "ccft perf: cannot find perf.py" >&2
    echo "  searched: ${candidates[*]}" >&2
    exit 1
fi

exec python3 "$perf_py" "$@"
