#!/usr/bin/env bash
#
# ccft-test - Run isolated smoke test

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/ccft-lib"
check_deps
check_files

log_info "Running smoke test..."

test_dir=$(mktemp -d)
test_config="$test_dir/ccft.json"
test_ledger="$test_dir/ledger.jsonl"
test_port=$((RANDOM % 5000 + 8000))
test_log="$test_dir/test.log"

echo '{"system_override": "test override"}' > "$test_config"

trap "kill %1 2>/dev/null; lsof -ti:$test_port | xargs kill 2>/dev/null; rm -rf $test_dir" EXIT

CCFT_CONFIG="$test_config" CCFT_LEDGER="$test_ledger" \
    mitmdump -p $test_port -s "$SCRIPT_DIR/../cc-flytrap.py" --set script.reloader=true \
    > "$test_log" 2>&1 &
sleep 2

response=$(HTTP_PROXY=http://127.0.0.1:$test_port HTTPS_PROXY=http://127.0.0.1:$test_port \
    NODE_EXTRA_CA_CERTS=~/.mitmproxy/mitmproxy-ca-cert.pem claude -p "test" 2>&1 | grep -v "^\[" | head -1)

if [ -z "$response" ]; then
    log_err "Smoke test failed: no response"
    exit 1
fi

log_info "Claude: $response"
sleep 1

if [ -f "$test_log" ]; then
    modified=$(grep "Modified:" "$test_log" 2>/dev/null | tail -1)
    [ -n "$modified" ] && log_info "Stripping: $modified"
fi

log_info "=== All tests passed ==="