#!/usr/bin/env bash
#
# ccft-ledger - Show/reset/archive usage records

ledger_file="$HOME/.local/share/ccft/ledger.jsonl"
archive_dir="$HOME/.local/share/ccft/archive"

case "$1" in
    reset)
        if [ ! -f "$ledger_file" ]; then
            echo "No ledger found"
            exit 1
        fi
        mkdir -p "$archive_dir"
        ts=$(date +%Y%m%d_%H%M%S)
        cp "$ledger_file" "$archive_dir/ledger_$ts.jsonl"
        echo "Archived to $archive_dir/ledger_$ts.jsonl"
        rm -f "$ledger_file"
        echo "Ledger reset"
        ;;
    show)
        if [ -f "$ledger_file" ]; then
            total=$(wc -l < "$ledger_file")
            echo "Records: $total"
            tail -5 "$ledger_file" | python3 -c "
import json,sys
for line in sys.stdin:
    r=json.loads(line)
    print(f\"{r['dt']} | {r['model'][:20]:20} | in:{r['in']:4} out:{r['out']:4} | lat:{r['lat']}ms\")" 2>/dev/null
        else
            echo "No ledger found"
        fi
        ;;
    records)
        if [ -f "$ledger_file" ]; then
            tail -20 "$ledger_file" | python3 -c "
import json,sys
for line in sys.stdin:
    r=json.loads(line)
    print(f\"{r['dt']} | {r['model'][:20]:20} | in:{r['in']:4} out:{r['out']:4} | lat:{r['lat']}ms | cip:{r.get('cip','')[:12]}\")" 2>/dev/null
        else
            echo "No ledger found"
        fi
        ;;
    archive)
        mkdir -p "$archive_dir"
        ts=$(date +%Y%m%d_%H%M%S)
        cp "$ledger_file" "$archive_dir/ledger_$ts.jsonl" 2>/dev/null || true
        echo "Archived to $archive_dir/ledger_$ts.jsonl"
        ;;
    *)
        echo "Usage: ccft ledger [reset|show|records|archive]"
        exit 1
        ;;
esac