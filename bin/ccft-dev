#!/usr/bin/env bash
#
# ccft-dev - Isolated development deployment for testing changes
# Usage: ./ccft-dev [start|stop|status|test|logs]
#
# This runs an isolated flytrap using:
# - Config: ~/.config/ccft/dev.json
# - Port: 7179 (dev port, won't conflict with production 7178)
# - Logs: ~/.local/share/ccft/dev/logs/

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEV_CONFIG="$HOME/.config/ccft/dev.json"
DEV_PORT="7179"
DEV_LOG_DIR="$HOME/.local/share/ccft/dev/logs"
DEV_PID_FILE="$HOME/.local/share/ccft/dev/.ccft.pid"

mkdir -p "$DEV_LOG_DIR"

load_config() {
    if [ -f "$DEV_CONFIG" ]; then
        PROXY_HOST=$(grep -o '"host"[[:space:]]*:[[:space:]]*"[^"]*"' "$DEV_CONFIG" | sed 's/.*"\(.*\)"/\1/' | head -1)
        PROXY_PORT_DEV=$(grep -o '"port"[[:space:]]*:[[:space:]]*[0-9]*' "$DEV_CONFIG" | grep -o '[0-9]*' | head -1)
    fi
    PROXY_HOST="${PROXY_HOST:-127.0.0.1}"
    PROXY_PORT_DEV="${PROXY_PORT_DEV:-$DEV_PORT}"
}

start_dev() {
    echo "Starting dev flytrap on $PROXY_HOST:$PROXY_PORT_DEV..."

    if lsof -ti:$PROXY_PORT_DEV 2>/dev/null; then
        echo "Dev flytrap already running on port $PROXY_PORT_DEV"
        return 0
    fi

    CCFT_CONFIG="$DEV_CONFIG" mitmdump -p $PROXY_PORT_DEV -s "$SCRIPT_DIR/cc-flytrap.py" --set script.reloader=true 2>&1 &
    pid=$!
    echo $pid > "$DEV_PID_FILE"
    sleep 2

    if kill -0 $pid 2>/dev/null; then
        echo "Dev flytrap started (PID $pid)"
        echo "Test with: HTTP_PROXY=$PROXY_HOST:$PROXY_PORT_DEV HTTPS_PROXY=$PROXY_HOST:$PROXY_PORT_DEV claude -p 'hi'"
    else
        rm -f "$DEV_PID_FILE"
        echo "Failed to start dev flytrap" >&2
        exit 1
    fi
}

stop_dev() {
    echo "Stopping dev flytrap..."

    if [ -f "$DEV_PID_FILE" ]; then
        pid=$(cat "$DEV_PID_FILE" 2>/dev/null)
        [ -n "$pid" ] && kill $pid 2>/dev/null
        rm -f "$DEV_PID_FILE"
    fi

    lsof -ti:$PROXY_PORT_DEV | xargs kill 2>/dev/null || true
    echo "Dev flytrap stopped"
}

status_dev() {
    if [ -f "$DEV_PID_FILE" ]; then
        pid=$(cat "$DEV_PID_FILE" 2>/dev/null)
        if [ -n "$pid" ] && kill -0 $pid 2>/dev/null; then
            echo "Running (PID $pid) on port $PROXY_PORT_DEV"
            return 0
        fi
    fi

    if lsof -i:$PROXY_PORT_DEV &>/dev/null; then
        echo "Running on port $PROXY_PORT_DEV (no PID file)"
        return 0
    fi

    echo "Not running"
}

logs_dev() {
    tail -50 "$DEV_LOG_DIR"/*.log 2>/dev/null || echo "No logs yet"
}

test_dev() {
    echo "[INFO] Running smoke test against dev instance..."
    HTTP_PROXY=$PROXY_HOST:$PROXY_PORT_DEV HTTPS_PROXY=$PROXY_HOST:$PROXY_PORT_DEV NODE_EXTRA_CA_CERTS=~/.mitmproxy/mitmproxy-ca-cert.pem claude -p "Say hi and confirm you got this test message" 2>&1 | tail -5
}

load_config

case "$1" in
    start)
        start_dev
        ;;
    stop)
        stop_dev
        ;;
    status)
        status_dev
        ;;
    test)
        test_dev
        ;;
    logs)
        logs_dev
        ;;
    *)
        echo "ccft-dev - Isolated dev deployment"
        echo ""
        echo "Usage: ccft-dev [start|stop|status|test|logs]"
        echo ""
        echo "Dev instance uses:"
        echo "  Config: $DEV_CONFIG"
        echo "  Port: $PROXY_PORT_DEV"
        echo "  Logs: $DEV_LOG_DIR"
        ;;
esac