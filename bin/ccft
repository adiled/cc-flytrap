#!/usr/bin/env bash
#
# ccft - Main entry point
# Delegates to subcommands

set -e
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/ccft-lib"

case "$1" in
    start)      exec "$SCRIPT_DIR/ccft-start" ;;
    stop)      exec "$SCRIPT_DIR/ccft-stop" ;;
    status)    exec "$SCRIPT_DIR/ccft-status" ;;
    test)      exec "$SCRIPT_DIR/ccft-test" ;;
    install)   exec "$SCRIPT_DIR/ccft-install" ;;
    uninstall) exec "$SCRIPT_DIR/ccft-uninstall" ;;
    update)    exec "$SCRIPT_DIR/ccft-update" ;;
    ledger)    exec "$SCRIPT_DIR/ccft-ledger" "${2:-}" ;;
    brainrot)  exec "$SCRIPT_DIR/ccft-brainrot" "${@:2}" ;;
    perf)      exec "$SCRIPT_DIR/ccft-perf" "${@:2}" ;;
    version|--version|-v) echo "ccft v$(cat "$SCRIPT_DIR/../VERSION")" ;;
    help|--help|-h|"") exec "$SCRIPT_DIR/ccft-help" ;;
    *) echo "Unknown command: $1" >&2; exec "$SCRIPT_DIR/ccft-help" ;;
esac
