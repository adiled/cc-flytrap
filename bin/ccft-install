#!/usr/bin/env bash
#
# ccft-install - Install as background service

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/ccft-lib"
load_config
check_deps check_files

mkdir -p "$HOME/.config/ccft"
if [ ! -f "$HOME/.config/ccft/ccft.json" ]; then
    cat > "$HOME/.config/ccft/ccft.json" << 'EOF'
{
  "system_override": "",
  "port": 7178,
  "host": "127.0.0.1",
  "pain": false,
  "ledger": true
}
EOF
    log_info "Created config: $HOME/.config/ccft/ccft.json"
fi

# Configure Claude to use proxy (using port from ccft config)
log_info "Configuring Claude to use proxy..."
if [ -f "$HOME/.claude.json" ]; then
    if ! grep -q '"HTTP_PROXY"' "$HOME/.claude.json"; then
        cp "$HOME/.claude.json" "$HOME/.claude.json.bak"
        if python3 -c "
import json, sys
try:
    with open('$HOME/.claude.json', 'r') as f:
        config = json.load(f)
    if 'env' not in config:
        config['env'] = {}
    config['env']['HTTP_PROXY'] = 'http://$PROXY_HOST:$PROXY_PORT'
    config['env']['HTTPS_PROXY'] = 'http://$PROXY_HOST:$PROXY_PORT'
    config['env']['NODE_EXTRA_CA_CERTS'] = '~/.mitmproxy/mitmproxy-ca-cert.pem'
    with open('$HOME/.claude.json', 'w') as f:
        json.dump(config, f, indent=2)
    print('ok')
except Exception as e:
    print('error:' + str(e), file=sys.stderr)
    sys.exit(1)
" 2>&1 | grep -q "^ok$"; then
            log_info "Updated ~/.claude.json with proxy settings ($PROXY_HOST:$PROXY_PORT)"
        else
            mv "$HOME/.claude.json.bak" "$HOME/.claude.json"
            log_err "Failed to update .claude.json - restored backup"
            exit 1
        fi
    else
        log_info "Claude config already has proxy settings"
    fi
else
    cat > "$HOME/.claude.json" << EOF
{
  "env": {
    "HTTP_PROXY": "http://$PROXY_HOST:$PROXY_PORT",
    "HTTPS_PROXY": "http://$PROXY_HOST:$PROXY_PORT",
    "NODE_EXTRA_CA_CERTS": "~/.mitmproxy/mitmproxy-ca-cert.pem"
  }
}
EOF
    log_info "Created ~/.claude.json with proxy settings ($PROXY_HOST:$PROXY_PORT)"
fi

log_info "Note: Claude will use proxy automatically. Restart Claude if already running."

mkdir -p "$HOME/.local/share/ccft/logs"
log_info "Installing on $(uname -s)..."

# Clean up stale files
rm -f "$SCRIPT_DIR/../ccft" "$SCRIPT_DIR/../install.sh"
rm -rf "$SCRIPT_DIR/../logs"
log_info "Cleaned up deprecated files"

# Add to PATH
mkdir -p "$HOME/.local/bin"
ln -sf "$HOME/.local/share/ccft/bin/ccft" "$HOME/.local/bin/ccft"
log_info "Added ccft to PATH (~/.local/bin)"

if [ "$(uname -s)" = "Darwin" ]; then
    plist="$HOME/Library/LaunchAgents/com.ccft.plist"
    mkdir -p "$HOME/Library/LaunchAgents"
    
    mitm_path=$(which mitmdump)
    sed "s|__MITMDUMP__|$mitm_path|g; s|__SCRIPT__|$SCRIPT_DIR/../cc-flytrap.py|g; s|__CWD__|$SCRIPT_DIR/../..|g; s|__LOGDIR__|$HOME/.local/share/ccft/logs|g; s|__PORT__|$PROXY_PORT|g" \
        > "$plist" << EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key><string>com.ccft</string>
    <key>ProgramArguments</key><array><string>__MITMDUMP__</string><string>-p</string><string>__PORT__</string><string>-s</string><string>__SCRIPT__</string></array>
    <key>WorkingDirectory</key><string>__CWD__</string>
    <key>RunAtLoad</key><true/>
    <key>KeepAlive</key><true/>
    <key>StandardOutPath</key><string>__LOGDIR__/launchd.log</string>
    <key>StandardErrorPath</key><string>__LOGDIR__/launchd.log</string>
</dict>
</plist>
EOF
    launchctl unload "$plist" 2>/dev/null || true
    launchctl load "$plist"
    log_info "Service installed: $plist"
elif [ "$(uname -s)" = "Linux" ]; then
    systemd_dir="$HOME/.config/systemd/user"
    mkdir -p "$systemd_dir"
    cat > "$systemd_dir/com.ccft.service" << 'EOF'
[Unit]
Description=ccft - Claude Code System Prompt Stripper
After=network.target

[Service]
Type=simple
User=%u
ExecStart=%h/.local/share/ccft/bin/ccft start
Restart=on-failure
RestartSec=5
WorkingDirectory=%h/.local/share/ccft
Environment=PATH=/usr/local/bin:%h/.local/bin:/usr/bin:/bin

[Install]
WantedBy=default.target
EOF
    systemctl --user daemon-reload
    systemctl --user enable --now com.ccft
    log_info "Service installed: com.ccft (systemd)"
fi

log_info "Install complete"